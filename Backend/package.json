{
  "name": "sritech-backend",
  "version": "1.0.0",
  "description": "Production-ready e-commerce backend for SriTech.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm install --prefix ../Frontend && npm run build --prefix ../Frontend",
    "test": "node --test ./tests/createOrder.test.js",
    "test:order": "node --test ./tests/createOrder.test.js",
    "normalize-products": "node normalize_products.js",
    "import-products": "node import_products.js",
    "lint": "eslint ."
  },
  "keywords": [
    "ecommerce",
    "node",
    "express",
    "mongodb",
    "razorpay",
    "cloudinary"
  ],
  "author": "SriTech",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.36.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.0.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb-memory-server": "^8.12.1",
    "mongoose": "^9.6.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.19.1",
    "razorpay": "^2.2.8",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "nodemon": "^3.0.1"
  }
}
